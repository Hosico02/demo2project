{
  "id": "node-cli-projectization",
  "name": "Node CLI projectization",
  "archetype": "node-cli",
  "description": "Drive a Node CLI demo to project-ready: README, .gitignore, .env.example, tests/smoke, CI workflow.",
  "recommended_standard": "node-cli",
  "default_profile": "balanced",
  "steps": [
    { "command": "analyze", "purpose": "snapshot + score" },
    { "command": "gap", "purpose": "identify missing files" },
    { "command": "qa:preflight", "purpose": "load QA cases" },
    { "command": "iterate --provider rule-based --max-iterations 2", "purpose": "scaffold README/.env.example/tests/CI" },
    { "command": "qa:regression", "purpose": "verify no regressions" },
    { "command": "report:project", "purpose": "share-able report" }
  ],
  "qa_patterns": ["process_failure/missing_validation_after_code_change", "verification_failure/test_failed"],
  "verification_commands": ["node --test tests", "node dist/index.js --help"],
  "common_risks": ["missing test coverage", "no CI workflow", "no .gitignore"],
  "success_criteria": ["score >= 50", "tests defined", "CI present"],
  "docs": "docs/guides/analyze-a-demo.md"
}
