{
  "id": "nextjs-app-projectization",
  "name": "Next.js app projectization",
  "archetype": "nextjs-app",
  "description": "Drive a Next.js demo to project-ready (build, env example, lint, smoke test).",
  "recommended_standard": "nextjs-app",
  "default_profile": "balanced",
  "steps": [
    { "command": "analyze", "purpose": "snapshot" },
    { "command": "gap", "purpose": "gap report" },
    { "command": "iterate --provider rule-based --max-iterations 2", "purpose": "scaffold" }
  ],
  "qa_patterns": ["verification_failure/test_failed"],
  "verification_commands": ["pnpm build", "pnpm lint"],
  "common_risks": ["missing .env.example", "no smoke test"],
  "success_criteria": ["next build succeeds"],
  "docs": "docs/guides/analyze-a-demo.md"
}
