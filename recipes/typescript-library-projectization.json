{
  "id": "typescript-library-projectization",
  "name": "TypeScript library projectization",
  "archetype": "typescript-library",
  "description": "Drive a TS lib to publishable state: tsconfig, build, exports, types, tests.",
  "recommended_standard": "typescript-library",
  "default_profile": "balanced",
  "steps": [
    { "command": "analyze", "purpose": "snapshot + score" },
    { "command": "gap", "purpose": "identify exports/types/tsconfig gaps" },
    { "command": "iterate --provider rule-based --max-iterations 2", "purpose": "scaffold tsconfig/build script/types" },
    { "command": "qa:regression", "purpose": "regression spec" }
  ],
  "qa_patterns": ["verification_failure/test_failed", "project_structure_failure/missing_config"],
  "verification_commands": ["pnpm build", "pnpm test"],
  "common_risks": ["missing types field in package.json", "no exports field", "no test setup"],
  "success_criteria": ["build succeeds", "types emitted", "tests run"],
  "docs": "docs/guides/analyze-a-demo.md"
}
