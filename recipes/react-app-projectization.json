{
  "id": "react-app-projectization",
  "name": "React app projectization",
  "archetype": "react-app",
  "description": "Drive a React/Vite demo to project-ready with build, tests, CI.",
  "recommended_standard": "react-app",
  "default_profile": "balanced",
  "steps": [
    { "command": "analyze", "purpose": "detect framework" },
    { "command": "gap", "purpose": "identify gaps" },
    { "command": "iterate --provider rule-based --max-iterations 2", "purpose": "scaffold CI/tests/README" }
  ],
  "qa_patterns": ["verification_failure/test_failed"],
  "verification_commands": ["pnpm build", "pnpm test"],
  "common_risks": ["missing build script", "no e2e tests", "no CI"],
  "success_criteria": ["build succeeds", "smoke test runs"],
  "docs": "docs/guides/analyze-a-demo.md"
}
