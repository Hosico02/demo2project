{
  "name": "generic-project",
  "required_files": ["README.md"],
  "recommended_files": [".gitignore", "docs", ".env.example"],
  "required_scripts": [],
  "recommended_scripts": [],
  "required_commands": [],
  "test_expectations": ["some form of test runner declared in docs"],
  "build_expectations": ["build/typecheck step or stated reason none is needed"],
  "docs_expectations": ["README explains purpose, install, usage"],
  "config_expectations": [".env.example or config/ explaining env vars"],
  "security_expectations": ["no real secrets committed", "no .env files tracked"],
  "ci_expectations": ["any CI config preferred but not required"],
  "scoring_rules": [
    {"dimension": "structure_score", "weight": 10},
    {"dimension": "test_score", "weight": 15},
    {"dimension": "build_score", "weight": 10},
    {"dimension": "runtime_score", "weight": 10},
    {"dimension": "docs_score", "weight": 12},
    {"dimension": "config_score", "weight": 10},
    {"dimension": "maintainability_score", "weight": 10},
    {"dimension": "safety_score", "weight": 10},
    {"dimension": "agent_process_score", "weight": 13}
  ],
  "quality_gates": [
    {"name": "tests_pass", "command": "test", "required": false, "description": "tests should pass if a runner is configured"}
  ],
  "forbidden_patterns": ["AKIA[0-9A-Z]{16}", "sk-[A-Za-z0-9]{20,}", "-----BEGIN [A-Z ]*PRIVATE KEY-----"],
  "verification_policy": {
    "require_evidence_when_files_changed": true,
    "max_command_timeout_ms": 120000,
    "forbid_unverified_completion": true
  }
}
