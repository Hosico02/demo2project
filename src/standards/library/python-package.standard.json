{
  "name": "python-package",
  "required_files": ["README.md", "pyproject.toml"],
  "recommended_files": [".gitignore", "src", "tests", ".env.example", "Makefile"],
  "required_scripts": [],
  "recommended_scripts": [],
  "required_commands": ["pytest"],
  "test_expectations": ["pytest discovers and runs tests/"],
  "build_expectations": ["python -m build (or hatch build / poetry build) succeeds"],
  "docs_expectations": ["README documents install + usage"],
  "config_expectations": [".env.example listing env vars"],
  "security_expectations": ["no secrets committed"],
  "ci_expectations": ["CI runs install + pytest"],
  "scoring_rules": [
    {"dimension": "structure_score", "weight": 12},
    {"dimension": "test_score", "weight": 18},
    {"dimension": "build_score", "weight": 12},
    {"dimension": "runtime_score", "weight": 6},
    {"dimension": "docs_score", "weight": 12},
    {"dimension": "config_score", "weight": 8},
    {"dimension": "maintainability_score", "weight": 10},
    {"dimension": "safety_score", "weight": 8},
    {"dimension": "agent_process_score", "weight": 14}
  ],
  "quality_gates": [
    {"name": "tests_pass", "command": "pytest", "required": true, "description": "pytest must pass"}
  ],
  "forbidden_patterns": ["AKIA[0-9A-Z]{16}", "sk-[A-Za-z0-9]{20,}", "-----BEGIN [A-Z ]*PRIVATE KEY-----"],
  "verification_policy": {
    "require_evidence_when_files_changed": true,
    "max_command_timeout_ms": 180000,
    "forbid_unverified_completion": true
  }
}
