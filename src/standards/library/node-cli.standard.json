{
  "name": "node-cli",
  "required_files": ["README.md", "package.json"],
  "recommended_files": [".gitignore", ".env.example", "tests", "bin", "src"],
  "required_scripts": ["test"],
  "recommended_scripts": ["build", "start"],
  "required_commands": ["test"],
  "test_expectations": ["unit test runner (vitest/jest/node:test) wired via npm test"],
  "build_expectations": ["build or typecheck script that exits 0"],
  "docs_expectations": ["README documents the CLI usage and install"],
  "config_expectations": [".env.example with each env var listed"],
  "security_expectations": ["package-lock.json or pnpm-lock.yaml committed", "no .env files tracked"],
  "ci_expectations": [".github/workflows or equivalent CI config"],
  "scoring_rules": [
    {"dimension": "structure_score", "weight": 10},
    {"dimension": "test_score", "weight": 18},
    {"dimension": "build_score", "weight": 12},
    {"dimension": "runtime_score", "weight": 12},
    {"dimension": "docs_score", "weight": 10},
    {"dimension": "config_score", "weight": 8},
    {"dimension": "maintainability_score", "weight": 10},
    {"dimension": "safety_score", "weight": 8},
    {"dimension": "agent_process_score", "weight": 12}
  ],
  "quality_gates": [
    {"name": "tests_pass", "command": "test", "required": true, "description": "unit tests must pass"},
    {"name": "build_succeeds", "command": "build", "required": false, "description": "build/typecheck if defined"}
  ],
  "forbidden_patterns": ["AKIA[0-9A-Z]{16}", "sk-[A-Za-z0-9]{20,}", "-----BEGIN [A-Z ]*PRIVATE KEY-----"],
  "verification_policy": {
    "require_evidence_when_files_changed": true,
    "max_command_timeout_ms": 120000,
    "forbid_unverified_completion": true
  }
}
