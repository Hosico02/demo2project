{
  "name": "typescript-library",
  "required_files": ["README.md", "package.json", "tsconfig.json"],
  "recommended_files": [".gitignore", "src", "tests", ".env.example", "CHANGELOG.md"],
  "required_scripts": ["test", "build"],
  "recommended_scripts": ["typecheck", "lint"],
  "required_commands": ["test", "build"],
  "test_expectations": ["test runner exits 0 with at least 1 assertion"],
  "build_expectations": ["tsc emits dist/ without errors"],
  "docs_expectations": ["README documents install + import + API surface"],
  "config_expectations": ["tsconfig with strict mode enabled"],
  "security_expectations": ["no secrets committed"],
  "ci_expectations": ["CI runs install + test + build"],
  "scoring_rules": [
    {"dimension": "structure_score", "weight": 12},
    {"dimension": "test_score", "weight": 18},
    {"dimension": "build_score", "weight": 14},
    {"dimension": "runtime_score", "weight": 6},
    {"dimension": "docs_score", "weight": 12},
    {"dimension": "config_score", "weight": 8},
    {"dimension": "maintainability_score", "weight": 10},
    {"dimension": "safety_score", "weight": 8},
    {"dimension": "agent_process_score", "weight": 12}
  ],
  "quality_gates": [
    {"name": "tests_pass", "command": "test", "required": true, "description": "unit tests must pass"},
    {"name": "build_succeeds", "command": "build", "required": true, "description": "tsc must succeed"}
  ],
  "forbidden_patterns": ["AKIA[0-9A-Z]{16}", "sk-[A-Za-z0-9]{20,}", "-----BEGIN [A-Z ]*PRIVATE KEY-----"],
  "verification_policy": {
    "require_evidence_when_files_changed": true,
    "max_command_timeout_ms": 120000,
    "forbid_unverified_completion": true
  }
}
