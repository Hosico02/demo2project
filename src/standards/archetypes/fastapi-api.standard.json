{
  "name": "fastapi-api",
  "required_files": ["README.md", "pyproject.toml"],
  "recommended_files": [".gitignore", "src", "tests", ".env.example", "Dockerfile", "Makefile"],
  "required_scripts": [],
  "recommended_scripts": [],
  "required_commands": ["pytest"],
  "test_expectations": ["pytest with TestClient for each route"],
  "build_expectations": ["dockerfile builds OR python -m build succeeds"],
  "docs_expectations": ["README documents endpoints + dev server + deploy"],
  "config_expectations": [".env.example listing env vars; pydantic Settings model preferred"],
  "security_expectations": ["no secrets committed; auth not stubbed in prod paths"],
  "ci_expectations": ["CI runs install + pytest + (optional) docker build"],
  "scoring_rules": [
    {"dimension": "structure_score", "weight": 10},
    {"dimension": "test_score", "weight": 18},
    {"dimension": "build_score", "weight": 12},
    {"dimension": "runtime_score", "weight": 10},
    {"dimension": "docs_score", "weight": 10},
    {"dimension": "config_score", "weight": 10},
    {"dimension": "maintainability_score", "weight": 10},
    {"dimension": "safety_score", "weight": 8},
    {"dimension": "agent_process_score", "weight": 12}
  ],
  "quality_gates": [
    {"name": "tests_pass", "command": "pytest", "required": true, "description": "pytest must pass"}
  ],
  "forbidden_patterns": ["AKIA[0-9A-Z]{16}", "sk-[A-Za-z0-9]{20,}", "-----BEGIN [A-Z ]*PRIVATE KEY-----"],
  "verification_policy": {
    "require_evidence_when_files_changed": true,
    "max_command_timeout_ms": 240000,
    "forbid_unverified_completion": true
  }
}
