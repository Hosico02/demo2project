{
  "name": "nextjs-app",
  "required_files": ["README.md", "package.json", "next.config.js"],
  "recommended_files": [".gitignore", "app", "pages", "public", ".env.example", "tsconfig.json"],
  "required_scripts": ["test", "build", "start"],
  "recommended_scripts": ["dev", "lint", "typecheck"],
  "required_commands": ["test", "build"],
  "test_expectations": ["unit + integration tests for routes/components", "browser-level UI smoke checks across desktop and mobile viewports"],
  "build_expectations": ["next build exits 0"],
  "docs_expectations": ["README documents dev/build/start + env config + UI verification"],
  "config_expectations": [".env.example listing every env var read in the codebase"],
  "security_expectations": ["server-only secrets never exposed via NEXT_PUBLIC_*"],
  "ci_expectations": ["CI runs install + lint + test + build"],
  "scoring_rules": [
    {"dimension": "structure_score", "weight": 10},
    {"dimension": "test_score", "weight": 15},
    {"dimension": "build_score", "weight": 14},
    {"dimension": "runtime_score", "weight": 10},
    {"dimension": "docs_score", "weight": 10},
    {"dimension": "config_score", "weight": 11},
    {"dimension": "maintainability_score", "weight": 10},
    {"dimension": "safety_score", "weight": 8},
    {"dimension": "agent_process_score", "weight": 12}
  ],
  "quality_gates": [
    {"name": "tests_pass", "command": "test", "required": true, "description": "tests"},
    {"name": "build_succeeds", "command": "build", "required": true, "description": "next build"}
  ],
  "forbidden_patterns": ["AKIA[0-9A-Z]{16}", "sk-[A-Za-z0-9]{20,}", "-----BEGIN [A-Z ]*PRIVATE KEY-----"],
  "verification_policy": {
    "require_evidence_when_files_changed": true,
    "max_command_timeout_ms": 240000,
    "forbid_unverified_completion": true
  }
}
