{
  "name": "docs-only-project",
  "required_files": ["README.md"],
  "recommended_files": ["docs", "mkdocs.yml", ".gitignore"],
  "required_scripts": [],
  "recommended_scripts": [],
  "required_commands": [],
  "test_expectations": ["link checker or markdown lint preferred"],
  "build_expectations": ["docs build (mkdocs / docusaurus) preferred; explicit no-build is acceptable"],
  "docs_expectations": ["README + table of contents; cross-references work; commands shown actually run somewhere"],
  "config_expectations": ["minimal; site config if a docs framework is used"],
  "security_expectations": ["no secrets in examples"],
  "ci_expectations": ["link checker / markdown lint in CI"],
  "scoring_rules": [
    {"dimension": "structure_score", "weight": 10},
    {"dimension": "test_score", "weight": 6},
    {"dimension": "build_score", "weight": 4},
    {"dimension": "runtime_score", "weight": 4},
    {"dimension": "docs_score", "weight": 30},
    {"dimension": "config_score", "weight": 8},
    {"dimension": "maintainability_score", "weight": 12},
    {"dimension": "safety_score", "weight": 8},
    {"dimension": "agent_process_score", "weight": 18}
  ],
  "quality_gates": [],
  "forbidden_patterns": ["AKIA[0-9A-Z]{16}", "sk-[A-Za-z0-9]{20,}", "-----BEGIN [A-Z ]*PRIVATE KEY-----"],
  "verification_policy": {
    "require_evidence_when_files_changed": true,
    "max_command_timeout_ms": 60000,
    "forbid_unverified_completion": false
  }
}
