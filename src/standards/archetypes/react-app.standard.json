{
  "name": "react-app",
  "required_files": ["README.md", "package.json"],
  "recommended_files": [".gitignore", "src", "tests", "public", ".env.example", "tsconfig.json"],
  "required_scripts": ["test", "build"],
  "recommended_scripts": ["dev", "start", "lint"],
  "required_commands": ["test", "build"],
  "test_expectations": ["component-level tests (vitest+jsdom or jest+rtl)"],
  "build_expectations": ["bundler build (vite/webpack/parcel) exits 0"],
  "docs_expectations": ["README documents dev server + build + deploy"],
  "config_expectations": [".env.example for VITE_/NEXT_PUBLIC_/REACT_APP_ vars"],
  "security_expectations": ["no secrets in client-bundled env vars"],
  "ci_expectations": ["CI runs install + test + build"],
  "scoring_rules": [
    {"dimension": "structure_score", "weight": 10},
    {"dimension": "test_score", "weight": 16},
    {"dimension": "build_score", "weight": 14},
    {"dimension": "runtime_score", "weight": 10},
    {"dimension": "docs_score", "weight": 10},
    {"dimension": "config_score", "weight": 10},
    {"dimension": "maintainability_score", "weight": 10},
    {"dimension": "safety_score", "weight": 8},
    {"dimension": "agent_process_score", "weight": 12}
  ],
  "quality_gates": [
    {"name": "tests_pass", "command": "test", "required": true, "description": "unit + component tests"},
    {"name": "build_succeeds", "command": "build", "required": true, "description": "bundler build"}
  ],
  "forbidden_patterns": ["AKIA[0-9A-Z]{16}", "sk-[A-Za-z0-9]{20,}", "-----BEGIN [A-Z ]*PRIVATE KEY-----"],
  "verification_policy": {
    "require_evidence_when_files_changed": true,
    "max_command_timeout_ms": 180000,
    "forbid_unverified_completion": true
  }
}
