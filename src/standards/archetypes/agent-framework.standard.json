{
  "name": "agent-framework",
  "required_files": ["README.md", "package.json"],
  "recommended_files": ["src/agents", "src/qa", "src/core", "tests", "qa/specs", "docs", ".gitignore"],
  "required_scripts": ["test", "build"],
  "recommended_scripts": ["typecheck", "lint"],
  "required_commands": ["test", "build"],
  "test_expectations": ["unit tests AND at least one workflow regression assertion"],
  "build_expectations": ["tsc/strict-mode succeeds"],
  "docs_expectations": ["README explains agent roles + provider seam; architecture doc"],
  "config_expectations": ["AgentProvider interface; no model-specific imports outside provider files"],
  "security_expectations": ["dangerous-command blocklist; secret redaction; no hardcoded keys"],
  "ci_expectations": ["CI runs install + test + build"],
  "scoring_rules": [
    {"dimension": "structure_score", "weight": 12},
    {"dimension": "test_score", "weight": 16},
    {"dimension": "build_score", "weight": 12},
    {"dimension": "runtime_score", "weight": 6},
    {"dimension": "docs_score", "weight": 12},
    {"dimension": "config_score", "weight": 8},
    {"dimension": "maintainability_score", "weight": 10},
    {"dimension": "safety_score", "weight": 12},
    {"dimension": "agent_process_score", "weight": 12}
  ],
  "quality_gates": [
    {"name": "tests_pass", "command": "test", "required": true, "description": "tests"},
    {"name": "build_succeeds", "command": "build", "required": true, "description": "build"}
  ],
  "forbidden_patterns": ["AKIA[0-9A-Z]{16}", "sk-[A-Za-z0-9]{20,}", "-----BEGIN [A-Z ]*PRIVATE KEY-----"],
  "verification_policy": {
    "require_evidence_when_files_changed": true,
    "max_command_timeout_ms": 180000,
    "forbid_unverified_completion": true
  }
}
