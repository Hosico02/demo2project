{
  "name": "monorepo",
  "required_files": ["README.md", "package.json"],
  "recommended_files": [".gitignore", "packages", "apps", "turbo.json", "pnpm-workspace.yaml", "CHANGELOG.md"],
  "required_scripts": ["test"],
  "recommended_scripts": ["build", "lint", "typecheck"],
  "required_commands": ["test"],
  "test_expectations": ["root test script aggregates package tests"],
  "build_expectations": ["root build affects all packages"],
  "docs_expectations": ["README explains workspace layout and per-package entry points"],
  "config_expectations": ["explicit workspace declaration (pnpm-workspace.yaml / package.workspaces)"],
  "security_expectations": ["no secrets committed; lockfile checked in"],
  "ci_expectations": ["CI uses affected/changed-package detection or runs all package tests"],
  "scoring_rules": [
    {"dimension": "structure_score", "weight": 14},
    {"dimension": "test_score", "weight": 16},
    {"dimension": "build_score", "weight": 12},
    {"dimension": "runtime_score", "weight": 8},
    {"dimension": "docs_score", "weight": 10},
    {"dimension": "config_score", "weight": 10},
    {"dimension": "maintainability_score", "weight": 12},
    {"dimension": "safety_score", "weight": 8},
    {"dimension": "agent_process_score", "weight": 10}
  ],
  "quality_gates": [
    {"name": "tests_pass", "command": "test", "required": true, "description": "root tests must pass"}
  ],
  "forbidden_patterns": ["AKIA[0-9A-Z]{16}", "sk-[A-Za-z0-9]{20,}", "-----BEGIN [A-Z ]*PRIVATE KEY-----"],
  "verification_policy": {
    "require_evidence_when_files_changed": true,
    "max_command_timeout_ms": 180000,
    "forbid_unverified_completion": true
  }
}
