{
  "version": "0.0.7",
  "description": "Demo2Project default security policy (Phase 7). Default-deny for high-risk actions; safe defaults for read/iterate workflows.",
  "default_decision": "deny",
  "default_reason": "no rule matched; default-deny for sensitive actions",
  "untrusted_repo_trust_threshold": "partially_trusted",
  "rules": [
    { "id": "R001", "action": "command_execution", "decision": "deny", "reason": "dangerous shell pattern", "match_command_regex": ["\\brm\\s+-rf?\\s+/", "\\bsudo\\b", "\\bshutdown\\b", "\\breboot\\b", "\\bmkfs\\b", "\\bdd\\s+if=", "curl[^|]*\\|\\s*(sh|bash)", "wget[^|]*\\|\\s*(sh|bash)", ":\\(\\)\\s*\\{\\s*:\\|:&\\s*\\}"], "risk_level": "critical" },
    { "id": "R002", "action": "command_execution", "decision": "allow_with_constraints", "reason": "safe commands allowed", "constraints": ["log to audit", "redact output"], "risk_level": "low" },
    { "id": "R003", "action": "file_read", "decision": "require_approval", "reason": "secret file access", "match_target_prefix": [".env", "id_rsa", "id_ed25519", "credentials", ".npmrc", ".pypirc", ".aws/credentials", ".ssh/"], "risk_level": "high", "approval_expires_ms": 900000 },
    { "id": "R004", "action": "file_read", "decision": "allow", "reason": "general read inside project", "risk_level": "low" },
    { "id": "R005", "action": "file_write", "decision": "require_approval", "reason": "high-risk path", "match_target_prefix": ["src/core/safety.ts", "src/core/redaction.ts", "src/core/approvalGate.ts", "src/core/autonomyPolicy.ts", "config/security-policy.json", "config/approval-policy.json", "config/autonomy-policy.json", "qa/specs/", "templates/claude/", ".github/workflows/", "package-lock.json", "pnpm-lock.yaml", "yarn.lock"], "risk_level": "high" },
    { "id": "R006", "action": "file_write", "decision": "allow", "reason": "normal write inside project", "risk_level": "low" },
    { "id": "R007", "action": "file_delete", "decision": "require_approval", "reason": "file deletion always reviewed", "risk_level": "medium" },
    { "id": "R008", "action": "network_access", "decision": "require_approval", "reason": "outbound network requires policy allow", "risk_level": "high" },
    { "id": "R009", "action": "dependency_install", "decision": "require_approval", "reason": "new dependency must be reviewed", "risk_level": "high" },
    { "id": "R010", "action": "package_script_execution", "decision": "deny", "reason": "lifecycle scripts denied for untrusted repos by default", "match_command_regex": ["postinstall", "preinstall", "prepare"], "risk_level": "high" },
    { "id": "R011", "action": "package_script_execution", "decision": "allow_with_constraints", "reason": "test/build scripts allowed", "constraints": ["audit log", "network_access still subject to its own rule"], "risk_level": "medium" },
    { "id": "R012", "action": "hook_installation", "decision": "require_approval", "reason": "hooks expand executor capability", "risk_level": "high" },
    { "id": "R013", "action": "plugin_installation", "decision": "require_approval", "reason": "plugin trust requires review", "risk_level": "high" },
    { "id": "R014", "action": "mcp_server_usage", "decision": "require_approval", "reason": "MCP can grant fs/network access", "risk_level": "high" },
    { "id": "R015", "action": "qa_memory_update", "decision": "allow_with_constraints", "reason": "repo-scope QA writes allowed with redaction", "constraints": ["redact", "audit log"], "risk_level": "low" },
    { "id": "R016", "action": "global_memory_update", "decision": "require_approval", "reason": "global QA memory edits require approval", "risk_level": "high" },
    { "id": "R017", "action": "project_standard_update", "decision": "require_approval", "reason": "standard updates affect future iterations across projects", "risk_level": "high" },
    { "id": "R018", "action": "self_iteration", "decision": "require_approval", "reason": "self-modification requires approval", "risk_level": "high" },
    { "id": "R019", "action": "approval_policy_update", "decision": "require_approval", "reason": "do not weaken approval policy without review", "risk_level": "critical" },
    { "id": "R020", "action": "verification_gate_update", "decision": "deny", "reason": "verification gate is immutable in default policy", "risk_level": "critical" },
    { "id": "R021", "action": "redaction_logic_update", "decision": "deny", "reason": "redaction logic is immutable in default policy", "risk_level": "critical" },
    { "id": "R022", "action": "evidence_graph_update", "decision": "allow_with_constraints", "reason": "writes routed through tamper-evident audit log", "constraints": ["audit log", "hash chain"], "risk_level": "medium" },
    { "id": "R023", "action": "replay_bundle_export", "decision": "allow_with_constraints", "reason": "exports must be redacted", "constraints": ["redact", "audit log"], "risk_level": "medium" },
    { "id": "R024", "action": "report_export", "decision": "allow_with_constraints", "reason": "reports redacted by default", "constraints": ["redact"], "risk_level": "low" },
    { "id": "R025", "action": "modify_security_policy", "decision": "require_approval", "reason": "security policy edits always require approval", "risk_level": "critical" }
  ]
}
