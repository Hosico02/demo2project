{
  "name": "matrixomnix",
  "version": "0.0.8",
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "description": "MatrixOmnix turns demos into production-ready products via a multi-agent harness with verification and QA learning.",
  "license": "MIT",
  "bin": {
    "matrixomnix": "./dist/cli/index.js",
    "demo2project": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo2project": "node dist/cli/index.js",
    "demo:stress": "node demo/run-stress.mjs --productize",
    "demo:stress:product-ready": "node demo/run-stress.mjs --productize --require-product-ready",
    "demo:stress:plan": "node demo/run-stress.mjs --plan-only",
    "analyze": "node dist/cli/index.js analyze",
    "gap": "node dist/cli/index.js gap",
    "plan": "node dist/cli/index.js plan",
    "iterate": "node dist/cli/index.js iterate",
    "qa:preflight": "node dist/cli/index.js qa:preflight",
    "qa:learn": "node dist/cli/index.js qa:learn",
    "qa:regression": "node dist/cli/index.js qa:regression",
    "self-check": "node dist/cli/index.js self-check",
    "init": "node dist/cli/index.js init",
    "matrixomnix": "node dist/cli/index.js",
    "site:dev": "pnpm --dir site dev",
    "site:build": "pnpm --dir site build",
    "site:preview": "pnpm --dir site preview",
    "site:check": "node scripts/site-check.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
